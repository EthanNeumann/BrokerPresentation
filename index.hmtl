  </div>
</section>

<!-- HOOK 3 -->
<section style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:120px 8vw;background:var(--dark);position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 50%, rgba(107,174,214,0.08) 0%, transparent 70%);pointer-events:none;"></div>
  <div style="position:relative;z-index:2;max-width:800px;">
    <div class="hook-raise reveal">
      Raise your hand if you've ever heard about one of these deals.<br><br>

</section>

<!-- WHO WE ARE -->
<section id="who">
  <div class="who-inner">
    <p class="who-label reveal">Who We Are</p>
    <h2 class="who-h reveal d2">Neumann Homes.</h2>
    <div class="who-mission reveal d3">
      We take on the homes <em>no one wants</em><br>
      and turn them into homes <em>everyone wants.</em>

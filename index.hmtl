  </div>

  <!-- $120k -->
  <div class="ben-stat" style="background:var(--dark);">
    <div>
      <div class="ben-stat-num reveal number-pop" data-count="120000" data-prefix="$" data-format="integer">0</div>
      <div class="ben-stat-label reveal d2">
        <strong class="">thousand dollars.</strong><br>Extra. Last year.
      </div>
      <div class="ben-stat-sub reveal d3">With less than 20 hours of work.</div>
    </div>
  </div>

  <!-- 4 deals -->
  <div class="ben-deals">
    <div class="ben-deals-inner">
      <div class="ben-deals-h reveal">He brought us <em style="color:var(--blue);font-style:normal;">4 deals.</em></div>
      <div class="deal-source reveal d1">
        <div class="deal-dot"></div>
        <div class="deal-text">One from his sphere.</div>
      </div>
      <div class="deal-source reveal d2">
        <div class="deal-dot"></div>
        <div class="deal-text">One from his cold calls.</div>
      </div>
      <div class="deal-source reveal d3">
        <div class="deal-dot"></div>
        <div class="deal-text">Two from people on his team.</div>
      </div>

</section>

<!-- BEN STORY -->
<section id="ben">

  <!-- Let me tell you a story -->
  <div class="ben-intro">
    <div>
      <p class="ben-story-label reveal">A True Story</p>
      <div class="ben-name reveal d2">Ben.</div>

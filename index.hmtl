      <path d="M5 26L20 2L35 26" stroke="#6BAED6" stroke-width="3.5" fill="none" stroke-linecap="round" opacity="0.55"/>
      <path d="M5 18L20-6L35 18" stroke="#6BAED6" stroke-width="3.5" fill="none" stroke-linecap="round" opacity="0.25"/>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Neumann Homes</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --blue: #6BAED6;
  --gold: #C8A96E;
  --dark: #0A0A0A;
  --charcoal: #141414;
  --white: #F0EDE8;
}
html { scroll-behavior: smooth; }
body {
  background: var(--dark);
  color: var(--white);
  font-family: 'DM Sans', sans-serif;
  overflow-x: hidden;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 24px 8vw;
  display: flex; justify-content: space-between; align-items: center;
  background: linear-gradient(to bottom, rgba(10,10,10,0.98), transparent);
}
.nav-logo {
  display: flex; align-items: center; gap: 12px;
  font-size: 14px; font-weight: 500; letter-spacing: 0.06em;
  color: var(--white);
}
.nav-cta {
  font-size: 12px; font-weight: 600; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--blue);
  text-decoration: none;
  border-bottom: 1px solid rgba(107,174,214,0.4);
  padding-bottom: 2px;
  transition: color 0.3s;
}
.nav-cta:hover { color: var(--white); border-color: var(--white); }

/* REVEAL */
.reveal {
  opacity: 0; transform: translateY(50px);
  transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
}
.reveal.visible { opacity: 1; transform: translateY(0); }
.d1 { transition-delay: 0.1s; }
.d2 { transition-delay: 0.2s; }
.d3 { transition-delay: 0.35s; }
.d4 { transition-delay: 0.5s; }
.d5 { transition-delay: 0.65s; }

/* ── HOOK SECTION ── */
#hook {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  padding: 120px 8vw;
  background: var(--dark);
  position: relative;
  overflow: hidden;
}
#hook::before {
  content: '$';
  font-family: 'Playfair Display', serif;
  font-size: 60vw; font-weight: 900;
  color: rgba(107,174,214,0.025);
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  line-height: 1;
}
.hook-content { position: relative; z-index: 2; max-width: 900px; }
.hook-opener {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 6vw, 80px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin-bottom: 24px;
}
.hook-opener em { color: var(--blue); font-style: normal; display: block; }
.hook-pause {
  font-size: clamp(18px, 2.5vw, 28px);
  font-weight: 300;
  color: rgba(240,237,232,0.55);
  line-height: 1.6;
  margin-bottom: 48px;
}
.hook-raise {
  font-size: clamp(20px, 2.5vw, 30px);
  font-weight: 500;
  color: var(--white);
  line-height: 1.5;
  border-top: 1px solid rgba(255,255,255,0.08);
  padding-top: 48px;
}
.hook-raise strong { color: var(--blue); }

/* ── BEN SECTION ── */
#ben {
  background: var(--charcoal);
  padding: 0;
}
.ben-intro {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  padding: 120px 8vw;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  position: relative;
}
.ben-story-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--blue);
  margin-bottom: 40px;
}
.ben-name {
  font-family: 'Playfair Display', serif;
  font-size: clamp(72px, 12vw, 160px);
  font-weight: 900;
  line-height: 0.9;
  letter-spacing: -0.03em;
  color: var(--white);
  margin-bottom: 32px;
}
.ben-tagline {
  font-size: clamp(18px, 2.2vw, 26px);
  font-weight: 300;
  color: rgba(240,237,232,0.55);
}
.ben-tagline strong { color: var(--white); font-weight: 600; }

/* Ben stat slides */
.ben-stat {
  min-height: 80vh;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  padding: 100px 8vw;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.ben-stat-num {
  font-family: 'Playfair Display', serif;
  font-size: clamp(80px, 15vw, 200px);
  font-weight: 900;
  line-height: 0.9;
  letter-spacing: -0.03em;
  color: var(--blue);
  margin-bottom: 24px;
}
.ben-stat-label {
  font-size: clamp(20px, 2.5vw, 32px);
  font-weight: 300;
  color: rgba(240,237,232,0.6);
  line-height: 1.5;
  max-width: 600px;
  margin: 0 auto;
}
.ben-stat-label strong { color: var(--white); font-weight: 600; }
.ben-stat-sub {
  margin-top: 16px;
  font-size: 16px; font-weight: 300;
  color: rgba(240,237,232,0.3);
  font-style: italic;
}

/* Ben deals breakdown */
.ben-deals {
  min-height: 80vh;
  display: flex; align-items: center; justify-content: center;
  padding: 100px 8vw;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.ben-deals-inner { max-width: 800px; width: 100%; }
.ben-deals-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(28px, 3.5vw, 48px);
  font-weight: 700;
  margin-bottom: 48px;
  text-align: center;
}
.deal-source {
  display: flex; align-items: center; gap: 24px;
  padding: 24px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.deal-source:last-child { border-bottom: none; }
.deal-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--blue);
  flex-shrink: 0;
}
.deal-text {
  font-size: clamp(16px, 2vw, 22px);
  font-weight: 300;
  color: rgba(240,237,232,0.7);
}

/* Math breakdown */
.ben-math {
  min-height: 80vh;
  display: flex; align-items: center; justify-content: center;
  padding: 100px 8vw;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  background: var(--dark);
}
.ben-math-inner { max-width: 800px; width: 100%; }
.ben-math-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(24px, 3vw, 40px);
  font-weight: 700;
  margin-bottom: 48px;
  color: rgba(240,237,232,0.5);
}
.math-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.math-row:last-child { border-bottom: none; }
.math-label {
  font-size: clamp(16px, 2vw, 22px);
  font-weight: 300;
  color: rgba(240,237,232,0.6);
}
.math-val {
  font-family: 'Playfair Display', serif;
  font-size: clamp(22px, 2.5vw, 32px);
  font-weight: 700;
  color: var(--blue);
}
.math-total {
  margin-top: 32px;
  padding: 40px;
  background: rgba(107,174,214,0.08);
  border: 1px solid rgba(107,174,214,0.2);
  border-radius: 4px;
  text-align: center;
}
.math-total-label {
  font-size: 13px; font-weight: 600;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--blue); margin-bottom: 16px;
}
.math-total-val {
  font-family: 'Playfair Display', serif;
  font-size: clamp(56px, 8vw, 100px);
  font-weight: 900;
  color: var(--white);
  line-height: 1;
}
.math-total-sub {
  margin-top: 12px;
  font-size: 16px; font-weight: 300;
  color: rgba(240,237,232,0.4);
}



  45%  { background-position: -20% center; }
  100% { background-position: -20% center; }
}

.float-soft { animation: floatSoft 4.5s ease-in-out infinite; }
@keyframes floatSoft {
  0%,100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.number-pop {
  text-shadow: 0 0 24px rgba(107,174,214,0.10);
  animation: numberPop 3.8s ease-in-out infinite;
}
@keyframes numberPop {
  0%,100% { transform: scale(1); text-shadow: 0 0 24px rgba(107,174,214,0.10); }
  50% { transform: scale(1.03); text-shadow: 0 0 42px rgba(107,174,214,0.22); }
}

.math-total {
  overflow: hidden;
  position: relative;
}
.math-total::before {
  content: '';
  position: absolute;
  inset: -20%;
  background: linear-gradient(115deg, transparent 30%, rgba(107,174,214,0.12) 50%, transparent 70%);
  transform: translateX(-70%) rotate(8deg);
  animation: cardSweep 5.5s ease-in-out infinite;
}
@keyframes cardSweep {
  0%, 55% { transform: translateX(-90%) rotate(8deg); opacity: 0; }
  65% { opacity: 1; }
  100% { transform: translateX(110%) rotate(8deg); opacity: 0; }
}
.math-total > * { position: relative; z-index: 2; }

.math-val, .ben-stat-num, .who-stat-val, .process-num {
  will-change: transform, text-shadow;
}

.ben-story-label,
.how-label,
.who-label,
.buy-label,
.process-label,
.cta-eyebrow,
.math-total-label {
  position: relative;
}
.ben-story-label::after,
.how-label::after,
.who-label::after,
.buy-label::after,
.process-label::after,
.cta-eyebrow::after,
.math-total-label::after {
  content: '';
  position: absolute;
  left: 0; bottom: -10px;
  width: 60px; height: 1px;
  background: linear-gradient(90deg, var(--blue), transparent);
  animation: linePulse 3.5s ease-in-out infinite;
}
@keyframes linePulse {
  0%,100% { width: 44px; opacity: 0.55; }
  50% { width: 84px; opacity: 1; }
}

/* Listings split layout */
.ben-listings {
  min-height: 78vh;
  display: grid;
  grid-template-columns: 1.08fr 0.92fr;
  align-items: stretch;
  background: var(--dark);
}
.ben-listings-bg {
  position: relative;
  min-height: 78vh;
  order: 2;
}
.ben-listings-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(1);
}
.ben-listings-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 5vw 80px 8vw;
  max-width: none;
}
.ben-listings-p {
  max-width: 560px;
}
.word-glow {
  text-shadow: 0 0 22px rgba(107,174,214,0.16);
}

/* Listings photo section */
.ben-listings {
  min-height: 70vh;
  position: relative;
  overflow: hidden;
  display: flex; align-items: center;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.ben-listings-bg {
  position: absolute; inset: 0;
}
.ben-listings-bg img {
  width: 100%; height: 100%;
  object-fit: cover;
  filter: brightness(0.25);
}
.ben-listings-content {
  position: relative; z-index: 2;
  padding: 80px 8vw;
  max-width: 700px;
}
.ben-listings-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 4vw, 56px);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 24px;
}
.ben-listings-h em { color: var(--blue); font-style: italic; }
.ben-listings-p {
  font-size: clamp(16px, 1.8vw, 22px);
  font-weight: 300;
  color: rgba(240,237,232,0.65);
  line-height: 1.7;
}

/* Who wants to be Ben */
.ben-cta {
  min-height: 80vh;
  display: flex; align-items: center; justify-content: center;
  text-align: center;
  padding: 100px 8vw;
  background: var(--dark);
  background-image: radial-gradient(ellipse 60% 50% at 50% 50%, rgba(107,174,214,0.08) 0%, transparent 70%);
}
.ben-cta-q {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 5.5vw, 72px);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 40px;
}
.ben-cta-q em { color: var(--blue); font-style: italic; }
.ben-cta-answer {
  font-size: clamp(18px, 2vw, 26px);
  font-weight: 300;
  color: rgba(240,237,232,0.5);
}

/* ── HOW SECTION ── */
#how {
  background: var(--charcoal);
  padding: 160px 8vw;
}
.how-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--blue); margin-bottom: 20px;
}
.how-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(40px, 6vw, 80px);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.02em;
  margin-bottom: 80px;
}
.how-items { display: flex; flex-direction: column; gap: 0; }
.how-item {
  display: flex; align-items: flex-start; gap: 48px;
  padding: 48px 0;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.how-item:last-child { border-bottom: none; }
.how-item-icon {
  font-size: clamp(24px, 3vw, 36px);
  flex-shrink: 0;
  margin-top: 4px;
  width: 60px;
  text-align: center;
}
.how-item-text {
  font-size: clamp(20px, 2.5vw, 30px);
  font-weight: 300;
  color: rgba(240,237,232,0.75);
  line-height: 1.5;
}
.how-item-text strong { color: var(--white); font-weight: 600; }
.how-cta {
  margin-top: 60px;
  font-size: clamp(18px, 2vw, 24px);
  font-weight: 600;
  color: var(--blue);
  letter-spacing: -0.01em;
}

/* ── WHO WE ARE ── */
#who {
  background: var(--dark);
  padding: 160px 8vw;
  position: relative;
  overflow: hidden;
}
#who::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 70% 60% at 80% 50%, rgba(107,174,214,0.07) 0%, transparent 60%);
  pointer-events: none;
}
.who-inner { position: relative; z-index: 2; max-width: 900px; }
.who-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--blue); margin-bottom: 20px;
}
.who-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(40px, 6vw, 80px);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.02em;
  margin-bottom: 48px;
}
.who-mission {
  font-family: 'Playfair Display', serif;
  font-size: clamp(22px, 2.8vw, 36px);
  font-weight: 700;
  font-style: italic;
  color: rgba(240,237,232,0.7);
  line-height: 1.4;
  border-left: 3px solid var(--blue);
  padding-left: 32px;
  margin-bottom: 60px;
}
.who-mission em { color: var(--blue); }
.who-stats {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin-bottom: 60px;
}
.who-stat {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  padding: 40px 32px;
  text-align: center;
  transition: background 0.3s, border-color 0.3s;
}
.who-stat:hover {
  background: rgba(107,174,214,0.06);
  border-color: rgba(107,174,214,0.2);
}
.who-stat-val {
  font-family: 'Playfair Display', serif;
  font-size: clamp(36px, 4vw, 56px);
  font-weight: 900; color: var(--blue);
  line-height: 1; margin-bottom: 12px;
}
.who-stat-label {
  font-size: 13px; font-weight: 300;
  color: rgba(240,237,232,0.45);
  letter-spacing: 0.05em; line-height: 1.4;
}

/* Before/after photos */
.who-photos {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 3px; height: 50vh;
}
.who-photo { position: relative; overflow: hidden; }
.who-photo img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.8s cubic-bezier(0.16,1,0.3,1);
  filter: brightness(0.8);
}
.who-photo:first-child img { filter: brightness(0.55) saturate(0.4); }
.who-photo:hover img { transform: scale(1.04); }
.who-photo-label {
  position: absolute; bottom: 20px; left: 20px;
  font-size: 11px; font-weight: 600; letter-spacing: 0.2em;
  text-transform: uppercase; padding: 7px 14px; border-radius: 20px;
}
.who-photo-label.before {
  background: rgba(0,0,0,0.5); border: 1px solid rgba(255,255,255,0.2);
  color: rgba(255,255,255,0.6);
}
.who-photo-label.after {
  background: rgba(107,174,214,0.2); border: 1px solid rgba(107,174,214,0.4);
  color: var(--blue);
}

/* ── WHAT WE BUY ── */
#buy {
  background: var(--charcoal);
  padding: 160px 8vw;
}
.buy-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--blue); margin-bottom: 20px;
}
.buy-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(40px, 6vw, 80px);
  font-weight: 900; line-height: 1.0;
  letter-spacing: -0.02em; margin-bottom: 16px;
}
.buy-sub {
  font-size: clamp(18px, 2vw, 24px);
  font-weight: 300; color: var(--blue);
  margin-bottom: 80px;
  font-style: italic;
}
.buy-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 3px;
}
.buy-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.06);
  padding: 48px;
  transition: background 0.3s, border-color 0.3s, transform 0.3s;
}
.buy-card:hover {
  background: rgba(107,174,214,0.06);
  border-color: rgba(107,174,214,0.25);
  transform: translateY(-4px);
}
.buy-card-title {
  font-size: clamp(22px, 2.5vw, 30px);
  font-weight: 600; color: var(--white);
  margin-bottom: 12px;
}
.buy-card-text {
  font-size: 16px; font-weight: 300;
  color: rgba(240,237,232,0.5); line-height: 1.6;
}

/* ── PROCESS ── */
#process {
  background: var(--dark);
  padding: 160px 8vw;
}
.process-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--blue); margin-bottom: 20px;
}
.process-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(40px, 6vw, 80px);
  font-weight: 900; line-height: 1.0;
  letter-spacing: -0.02em; margin-bottom: 80px;
}
.process-steps {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 0; position: relative;
}
.process-steps::before {
  content: ''; position: absolute;
  top: 28px; left: 28px; right: 28px; height: 1px;
  background: linear-gradient(to right, var(--blue), rgba(107,174,214,0.1));
}
.process-step { padding-right: 32px; }
.process-num {
  width: 56px; height: 56px; border-radius: 50%;
  background: var(--dark); border: 2px solid var(--blue);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 22px; font-weight: 700; color: var(--blue);
  margin-bottom: 28px; position: relative; z-index: 2;
}
.process-title {
  font-size: 18px; font-weight: 600;
  margin-bottom: 12px; color: var(--white);
}
.process-text {
  font-size: 15px; font-weight: 300;
  color: rgba(240,237,232,0.5); line-height: 1.65;
}

/* ── FINAL CTA ── */
#cta {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  text-align: center; padding: 120px 8vw;
  background: var(--dark);
  position: relative; overflow: hidden;
}
.cta-ring {
  position: absolute; border-radius: 50%;
  border: 1px solid rgba(107,174,214,0.07);
  animation: expand 5s linear infinite;
}
.cta-ring:nth-child(1) { width: 400px; height: 400px; animation-delay: 0s; }
.cta-ring:nth-child(2) { width: 650px; height: 650px; animation-delay: 1.7s; }
.cta-ring:nth-child(3) { width: 900px; height: 900px; animation-delay: 3.4s; }
@keyframes expand {
  0% { opacity: 0.5; transform: scale(0.7); }
  100% { opacity: 0; transform: scale(1.4); }
}
.cta-content { position: relative; z-index: 2; }
.cta-eyebrow {
  font-size: 11px; font-weight: 600; letter-spacing: 0.35em;
  text-transform: uppercase; color: var(--blue); margin-bottom: 32px;
}
.cta-h {
  font-family: 'Playfair Display', serif;
  font-size: clamp(56px, 9vw, 120px);
  font-weight: 900; line-height: 0.9;
  letter-spacing: -0.03em; margin-bottom: 32px;
}
.cta-sub {
  font-size: clamp(16px, 1.8vw, 22px);
  font-weight: 300; color: rgba(240,237,232,0.45);
  margin-bottom: 56px;
}
.cta-phone {
  display: inline-flex; align-items: center; gap: 16px;
  background: var(--blue); color: white;
  font-size: clamp(20px, 2.5vw, 28px); font-weight: 600;
  padding: 22px 56px; border-radius: 60px;
  text-decoration: none;
  transition: transform 0.3s, box-shadow 0.3s;
  box-shadow: 0 0 60px rgba(107,174,214,0.2);
}
.cta-phone:hover {
  transform: translateY(-4px);
  box-shadow: 0 24px 80px rgba(107,174,214,0.35);
}
.cta-be-ben {
  margin-top: 48px;
  font-family: 'Playfair Display', serif;
  font-size: clamp(18px, 2vw, 26px);
  font-style: italic;
  color: rgba(240,237,232,0.3);
}
.cta-be-ben em { color: var(--blue); }

footer {
  background: #060606; padding: 40px 8vw;
  display: flex; justify-content: space-between; align-items: center;
  border-top: 1px solid rgba(255,255,255,0.05);
}
.footer-l { font-size: 13px; font-weight: 300; color: rgba(240,237,232,0.25); }
.footer-r { font-size: 13px; color: var(--blue); }

@media (max-width: 768px) {
  .who-stats { grid-template-columns: 1fr; }
  .buy-grid { grid-template-columns: 1fr; }
  .process-steps { grid-template-columns: 1fr 1fr; gap: 40px; }
  .process-steps::before { display: none; }
  .who-photos { height: 40vh; }
  .ben-math-inner { padding: 0; }
  .math-row { flex-direction: column; gap: 8px; }
  .ben-listings {
    grid-template-columns: 1fr;
  }
  .ben-listings-bg {
    min-height: 38vh;
    order: 0;
  }
  .ben-listings-content {
    padding: 56px 8vw;
  }
}
/* 2.4M shimmer animation */
.stat-volume {
  color: rgba(240,237,232,0.55) !important;
  background: linear-gradient(
    120deg,
    rgba(240,237,232,0.35) 0%,
    rgba(240,237,232,0.7) 38%,
    rgba(255,255,255,0.98) 50%,
    rgba(240,237,232,0.7) 62%,
    rgba(240,237,232,0.35) 100%
  );
  background-size: 250% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 3.5s ease-in-out infinite;
}
@keyframes shimmer {
  0%   { background-position: 200% center; }
  60%  { background-position: -50% center; }
  100% { background-position: -50% center; }
}

.center-slide {
  display:flex;
  align-items:center;
  justify-content:center;
  height:100vh;
  text-align:center;
  padding:0 80px;
}
.center-slide h1 {
  font-family: 'Playfair Display', serif;
  font-size: 96px;
  line-height:1.1;
  max-width:1100px;
  margin:0 auto;
}

</style>
</head>
<body>

<!-- NAV -->
<nav>

      <div class="math-row reveal d2">
        <div class="math-label">Listing side commission</div>
        <div class="math-val number-pop" data-count="2.6" data-suffix="%" data-format="decimal" data-decimals="1">0.0%</div>
      </div>
      <div class="math-row reveal d3">
        <div class="math-label">On every single deal.</div>
        <div class="math-val number-pop" style="color:var(--white);" data-count="4" data-prefix="All " data-suffix="." data-format="integer">All 0.</div>
      </div>
      <div class="math-total reveal d4">
        <div class="math-total-label">Total Commission</div>
        <div class="math-total-val number-pop" data-count="120000" data-prefix="$" data-format="integer">$0</div>
        <div class="math-total-sub">Less than 20 hours of work.</div>
      </div>
    </div>
  </div>

  <!-- The listings -->
  <div class="ben-listings">
    <div class="ben-listings-bg">
      <img src="data:image/jpeg;base64," alt="Renovated home">

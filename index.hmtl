  </div>

  <!-- $2.4M - eh -->
  <div class="ben-stat" style="background:var(--dark);">
    <div>
      <div class="ben-stat-num reveal stat-volume number-pop" data-count="2.4" data-prefix="$" data-suffix="M" data-format="decimal" data-decimals="1">$0.0M</div>

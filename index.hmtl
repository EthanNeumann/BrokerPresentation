    <div class="who-stats">
      <div class="who-stat reveal d1">
        <div class="who-stat-val">30–40</div>
        <div class="who-stat-label">Homes renovated<br>per year</div>
      </div>
      <div class="who-stat reveal d2">
        <div class="who-stat-val">100%</div>
        <div class="who-stat-label">Guaranteed<br>closing rate</div>
      </div>
      <div class="who-stat reveal d3">
        <div class="who-stat-val">7</div>
        <div class="who-stat-label">Days minimum<br>to close</div>
      </div>
    </div>
  </div>
  <div class="who-photos reveal">
    <div class="who-photo">
      <img src="data:image/jpeg;base64," alt="Before">
      <div class="who-photo-label before">Before</div>
    </div>
    <div class="who-photo">
      <img src="data:image/jpeg;base64," alt="After">
      <div class="who-photo-label after">After</div>
    </div>
  </div>
</section>

<!-- WHAT WE BUY -->
<section id="buy">
  <p class="buy-label reveal">Buy Box</p>
  <h2 class="buy-h reveal d2">What we buy.</h2>
  <p class="buy-sub reveal d3">If it's distressed and it's in the Triangle, we want to see it.</p>
  <div class="buy-grid">
    <div class="buy-card reveal d1">
      <div class="buy-card-title">SFR & Townhomes</div>
      <div class="buy-card-text">Single family homes and attached townhomes. Residential only.</div>
    </div>
    <div class="buy-card reveal d2">
      <div class="buy-card-title">Any Price Point</div>
      <div class="buy-card-text">Starter homes to high-end renovations. We underwrite everything.</div>
    </div>
    <div class="buy-card reveal d3">
      <div class="buy-card-title">Any Condition</div>
      <div class="buy-card-text">Full gut to light cosmetic. Hoarders, estates, foreclosures. We've seen worse.</div>
    </div>
    <div class="buy-card reveal d4">
      <div class="buy-card-title">Within 45 Min of Raleigh</div>
      <div class="buy-card-text">Triangle area and surrounding markets. Durham, Chapel Hill, Cary, Wake Forest, Apex.</div>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section id="process">
  <p class="process-label reveal">How It Works</p>
  <h2 class="process-h reveal d2">Four steps.<br>That's it.</h2>
  <div class="process-steps">
    <div class="process-step reveal d1">
      <div class="process-num">1</div>
      <div class="process-title">Text Audrey</div>
      <div class="process-text">Address. Condition. What the seller needs. That's all she needs to get started.</div>
    </div>
    <div class="process-step reveal d2">
      <div class="process-num">2</div>
      <div class="process-title">Same-Day Offer</div>
      <div class="process-text">Soft offer the same day. No waiting. No committees. No runaround.</div>
    </div>
    <div class="process-step reveal d3">
      <div class="process-num">3</div>
      <div class="process-title">We Close</div>
      <div class="process-text">7 days if they need it. 60 days if they need time. 100% guaranteed. We don't back out.</div>
    </div>
    <div class="process-step reveal d4">
      <div class="process-num">4</div>
      <div class="process-title">You List It</div>
      <div class="process-text">We renovate. We call you. You show up to a clean, staged, renovated house. You sell it. You collect both checks.</div>
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section id="cta">
  <div class="cta-ring"></div>
  <div class="cta-ring"></div>
  <div class="cta-ring"></div>
  <div class="cta-content">
    <p class="cta-eyebrow reveal">One phone call. Two commissions. Zero extra marketing.</p>
    <h2 class="cta-h reveal d2">Text Audrey<br>Right Now.</h2>
    <p class="cta-sub reveal d3">Your name. That's all she needs.</p>
    <a href="tel:9197984128" class="cta-phone reveal d4">
      📱 (919) 798-4128
    </a>
    <p class="cta-be-ben reveal d5"><em>Be like Ben.</em></p>
  </div>
</section>

<footer>
  <div class="footer-l">© 2025 Neumann Homes · ENN LLC · Triangle, NC</div>
  <div class="footer-r">Audrey · (919) 798-4128</div>
</footer>


<script>
// Scroll reveal
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      if (e.target.classList.contains('number-pop')) {
        e.target.classList.add('is-live');
      }
    }
  });
}, { threshold: 0.12 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

function formatAnimatedValue(value, el) {
  const prefix = el.dataset.prefix || '';
  const suffix = el.dataset.suffix || '';
  const format = el.dataset.format || 'integer';
  const decimals = parseInt(el.dataset.decimals || (format === 'decimal' ? '1' : '0'), 10);

  let formatted = value;
  if (format === 'decimal') {
    formatted = Number(value).toFixed(decimals);
  } else {
    formatted = Math.round(value).toLocaleString();
  }
  return `${prefix}${formatted}${suffix}`;
}

function animateCount(el, duration = 2200) {
  const target = parseFloat(el.dataset.count || '0');
  const startTime = performance.now();
  const startValue = 0;

  function frame(now) {
    const progress = Math.min((now - startTime) / duration, 1);
    const eased = 1 - Math.pow(1 - progress, 3);
    const current = startValue + (target - startValue) * eased;
    el.textContent = formatAnimatedValue(current, el);

    if (progress < 1) {
      requestAnimationFrame(frame);
    } else {
      el.textContent = formatAnimatedValue(target, el);
      el.classList.add('is-complete');
    }
  }

  requestAnimationFrame(frame);
}

const countObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting && e.target.dataset.count && !e.target.dataset.played) {
      e.target.dataset.played = 'true';
      animateCount(e.target, parseInt(e.target.dataset.duration || '2200', 10));
      countObserver.unobserve(e.target);
    }
  });
}, { threshold: 0.45 });

document.querySelectorAll('[data-count]').forEach(el => countObserver.observe(el));
</script>
</body>
</html>
